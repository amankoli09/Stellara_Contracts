// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  email            String? @unique
  pushSubscription Json?   @map("push_subscription")

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  reputationActivities ReputationActivity[] @relation("ReputationSubject")
  triggeredActivities  ReputationActivity[] @relation("ReputationActor")
  reputationBreakdown  ReputationScore?
  notificationSettings NotificationSetting?
  notifications        Notification[]
  
  // Invoice Factoring Relations
  soldInvoices         Invoice[]            @relation("InvoiceSeller")
  bids                 Bid[]                @relation("BidInvestor")
  defaultClaims        DefaultClaim[]       @relation("DefaultClaimant")
  accountingIntegration AccountingIntegration? @relation("AccountingUser")
  competitionParticipants CompetitionParticipant[]
  competitionLeaderboard CompetitionLeaderboard[]
  competitionAchievements CompetitionAchievement[]
  antiCheatFlags      AntiCheatFlag[]
  prizeDistributions  PrizeDistribution[]

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}

model ReputationActivity {
  id           String       @id @default(cuid())
  subjectId    String       @map("subject_id")
  subject      User         @relation("ReputationSubject", fields: [subjectId], references: [id])
  actorId      String?      @map("actor_id")
  actor        User?        @relation("ReputationActor", fields: [actorId], references: [id])
  activityType ActivityType @map("activity_type")
  value        Decimal      @db.Decimal(18, 4)
  referenceId  String?      @map("reference_id")
  occurredAt   DateTime     @map("occurred_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([subjectId])
  @@index([subjectId, activityType])
  @@index([occurredAt])
  @@map("reputation_activities")
}

model ReputationScore {
  id                     String   @id @default(cuid())
  subjectId              String   @unique @map("subject_id")
  subject                User     @relation(fields: [subjectId], references: [id])
  compositeScore         Decimal  @map("composite_score") @db.Decimal(6, 2)
  successRateScore       Decimal  @map("success_rate_score") @db.Decimal(6, 2)
  peerRatingScore        Decimal  @map("peer_rating_score") @db.Decimal(6, 2)
  contributionSizeScore  Decimal  @map("contribution_size_score") @db.Decimal(6, 2)
  communityFeedbackScore Decimal  @map("community_feedback_score") @db.Decimal(6, 2)
  activityCount          Int      @map("activity_count")
  lowConfidence          Boolean  @default(false) @map("low_confidence")
  calculatedAt           DateTime @updatedAt @map("calculated_at")

  @@map("reputation_scores")
}

enum ActivityType {
  SUCCESSFUL_TRANSACTION
  FAILED_TRANSACTION
  PEER_RATING
  COMMUNITY_REVIEW
  DISPUTE_WON
  DISPUTE_LOST
  HIGH_VALUE_CONTRIBUTION
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@map("processed_events")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  notifyContributions Boolean  @default(true) @map("notify_contributions")
  notifyMilestones    Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean  @default(true) @map("notify_deadlines")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json? // Optional metadata (e.g., projectId)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// Insurance Module Models

enum RiskType {
  PROJECT_FAILURE
  SMART_CONTRACT_EXPLOIT
  MARKET_VOLATILITY
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model InsurancePolicy {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  poolId         String    @map("pool_id")
  riskType       RiskType  @map("risk_type")
  premium        Decimal   @map("premium")
  coverageAmount Decimal   @map("coverage_amount")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("insurance_policies")
}

model InsurancePool {
  id            String   @id @default(cuid())
  name          String
  capital       Decimal  @default(0)
  lockedCapital Decimal  @default(0) @map("locked_capital")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("insurance_pools")
}

model Claim {
  id           String      @id @default(cuid())
  policyId     String      @map("policy_id")
  claimAmount  Decimal     @map("claim_amount")
  status       ClaimStatus @default(PENDING)
  payoutAmount Decimal?    @map("payout_amount")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("claims")
}

model ReinsuranceContract {
  id             String   @id @default(cuid())
  poolId         String   @map("pool_id")
  coverageLimit  Decimal  @map("coverage_limit")
  premiumRate    Decimal  @map("premium_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("reinsurance_contracts")
}

// Invoice Factoring Marketplace Models

model Invoice {
  id                String           @id @default(cuid())
  sellerId          String           @map("seller_id")
  seller            User             @relation("InvoiceSeller", fields: [sellerId], references: [id])
  invoiceNumber     String           @map("invoice_number")
  buyerName         String           @map("buyer_name")
  buyerEmail        String?          @map("buyer_email")
  buyerAddress      String?          @map("buyer_address")
  amount            Decimal          @db.Decimal(18, 2)
  currency          String           @default("USD")
  issueDate         DateTime         @map("issue_date")
  dueDate           DateTime         @map("due_date")
  description       String?
  pdfUrl            String?          @map("pdf_url")
  ocrData           Json?            @map("ocr_data")
  verificationToken String           @unique @map("verification_token")
  isVerified        Boolean          @default(false) @map("is_verified")
  verifiedAt        DateTime?        @map("verified_at")
  verifiedBy        String?          @map("verified_by")
  status            InvoiceStatus    @default(DRAFT)
  auctionId         String?          @map("auction_id")
  auction           Auction?         @relation("InvoiceAuction")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  bids               Bid[]
  payments           Payment[]
  defaultClaims      DefaultClaim[]

  @@map("invoices")
}

model Auction {
  id                String            @id @default(cuid())
  invoiceId         String            @unique @map("invoice_id")
  invoice           Invoice           @relation("InvoiceAuction", fields: [invoiceId], references: [id])
  startAmount       Decimal           @map("start_amount") @db.Decimal(18, 2)
  currentBestBid    Decimal?          @map("current_best_bid") @db.Decimal(5, 4)
  currentBestBidder String?           @map("current_best_bidder")
  minAdvanceRate    Decimal           @default(80) @map("min_advance_rate") @db.Decimal(5, 2)
  maxAdvanceRate    Decimal           @default(95) @map("max_advance_rate") @db.Decimal(5, 2)
  startTime         DateTime          @map("start_time")
  endTime           DateTime          @map("end_time")
  status            AuctionStatus     @default(ACTIVE)
  winningBidId      String?           @map("winning_bid_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  bids              Bid[]

  @@map("auctions")
}

model Bid {
  id                String           @id @default(cuid())
  auctionId         String           @map("auction_id")
  auction           Auction          @relation(fields: [auctionId], references: [id])
  invoiceId         String           @map("invoice_id")
  invoice           Invoice          @relation(fields: [invoiceId], references: [id])
  investorId        String           @map("investor_id")
  investor          User             @relation("BidInvestor", fields: [investorId], references: [id])
  advanceRate       Decimal          @map("advance_rate") @db.Decimal(5, 2)
  discountRate      Decimal          @map("discount_rate") @db.Decimal(5, 4)
  advanceAmount     Decimal          @map("advance_amount") @db.Decimal(18, 2)
  expectedReturn    Decimal          @map("expected_return") @db.Decimal(18, 2)
  isWinning         Boolean          @default(false) @map("is_winning")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@map("bids")
}

model Payment {
  id                String           @id @default(cuid())
  invoiceId         String           @map("invoice_id")
  invoice           Invoice          @relation(fields: [invoiceId], references: [id])
  type              PaymentType
  amount            Decimal          @db.Decimal(18, 2)
  currency          String           @default("USD")
  transactionHash   String?          @unique @map("transaction_hash")
  status            PaymentStatus    @default(PENDING)
  processedAt       DateTime?        @map("processed_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("payments")
}

model DefaultClaim {
  id                String           @id @default(cuid())
  invoiceId         String           @map("invoice_id")
  invoice           Invoice          @relation(fields: [invoiceId], references: [id])
  claimantId        String           @map("claimant_id")
  claimant          User             @relation("DefaultClaimant", fields: [claimantId], references: [id])
  claimAmount       Decimal          @map("claim_amount") @db.Decimal(18, 2)
  reason            String
  status            ClaimStatus      @default(PENDING)
  payoutAmount      Decimal?         @map("payout_amount") @db.Decimal(18, 2)
  processedAt       DateTime?        @map("processed_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("default_claims")
}

model InvoiceInsurancePool {
  id                String           @id @default(cuid())
  name              String
  totalCapital      Decimal          @default(0) @map("total_capital") @db.Decimal(18, 2)
  lockedCapital     Decimal          @default(0) @map("locked_capital") @db.Decimal(18, 2)
  premiumRate       Decimal          @default(0.01) @map("premium_rate") @db.Decimal(6, 6)
  coveragePercentage Decimal         @default(100) @map("coverage_percentage") @db.Decimal(5, 2)
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("invoice_insurance_pools")
}

model AccountingIntegration {
  id                String           @id @default(cuid())
  userId            String           @unique @map("user_id")
  user              User             @relation("AccountingUser", fields: [userId], references: [id])
  provider          AccountingProvider
  apiKey            String           @map("api_key")
  companyId         String           @map("company_id")
  isActive          Boolean          @default(true) @map("is_active")
  lastSyncAt        DateTime?        @map("last_sync_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("accounting_integrations")
}

enum InvoiceStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  IN_AUCTION
  FUNDED
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum AuctionStatus {
  ACTIVE
  ENDED
  CANCELLED
}

enum PaymentType {
  ADVANCE
  FULL_PAYMENT
  INSURANCE_PAYOUT
  CLAIM_PAYMENT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AccountingProvider {
  QUICKBOOKS
  XERO
  FRESHBOOKS
  WAVE
// Trading Competition Models

model TradingCompetition {
  id                  String               @id @default(cuid())
  title               String
  description         String?
  type                CompetitionType
  durationType        DurationType
  startTime           DateTime             @map("start_time")
  endTime             DateTime             @map("end_time")
  status              CompetitionStatus    @default(UPCOMING)
  prizePool           Decimal              @default(0) @map("prize_pool")
  maxParticipants     Int?                 @map("max_participants")
  minDeposit          Decimal              @default(0) @map("min_deposit")
  requiredKycTier     Int                  @default(0) @map("required_kyc_tier")
  entryFee            Decimal              @default(0) @map("entry_fee")
  prizeDistribution   Json                 @map("prize_distribution")
  rules               Json?
  createdBy           String               @map("created_by")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  // Relations
  participants        CompetitionParticipant[]
  leaderboard         CompetitionLeaderboard[]
  trades              CompetitionTrade[]
  achievements         CompetitionAchievement[]
  antiCheatFlags      AntiCheatFlag[]
  prizeDistributions  PrizeDistribution[]

  @@map("trading_competitions")
}

model CompetitionParticipant {
  id             String     @id @default(cuid())
  competitionId  String     @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String     @map("user_id")
  user           User       @relation(fields: [userId], references: [id])
  status         ParticipantStatus @default(REGISTERED)
  joinedAt       DateTime   @default(now()) @map("joined_at")
  initialBalance Decimal    @default(0) @map("initial_balance")
  finalBalance   Decimal?   @map("final_balance")
  totalVolume    Decimal    @default(0) @map("total_volume")
  totalReturn    Decimal    @default(0) @map("total_return")
  sharpeRatio    Decimal?   @map("sharpe_ratio")
  maxDrawdown    Decimal    @default(0) @map("max_drawdown")
  winRate        Decimal    @default(0) @map("win_rate")
  rank           Int?
  prizeAmount    Decimal?   @map("prize_amount")
  disqualified   Boolean    @default(false) @map("disqualified")
  disqualificationReason String? @map("disqualification_reason")
  
  // Relations
  trades         CompetitionTrade[]
  
  @@unique([competitionId, userId])
  @@map("competition_participants")
}

model CompetitionTrade {
  id              String     @id @default(cuid())
  competitionId   String     @map("competition_id")
  competition     TradingCompetition @relation(fields: [competitionId], references: [id])
  participantId   String     @map("participant_id")
  participant     CompetitionParticipant @relation(fields: [participantId], references: [id])
  userId          String     @map("user_id")
  asset           String
  side            TradeSide
  quantity        Decimal
  price           Decimal
  totalValue      Decimal    @map("total_value")
  fee             Decimal    @default(0)
  timestamp       DateTime   @default(now())
  transactionHash String?    @map("transaction_hash")
  profitLoss      Decimal?   @map("profit_loss")
  
  @@index([competitionId, userId])
  @@index([participantId])
  @@index([timestamp])
  @@map("competition_trades")
}

model CompetitionLeaderboard {
  id             String     @id @default(cuid())
  competitionId  String     @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String     @map("user_id")
  user           User       @relation(fields: [userId], references: [id])
  rank           Int
  score          Decimal
  totalReturn    Decimal    @map("total_return")
  totalVolume    Decimal    @map("total_volume")
  sharpeRatio    Decimal?   @map("sharpe_ratio")
  maxDrawdown    Decimal    @map("max_drawdown")
  winRate        Decimal    @map("win_rate")
  lastUpdated    DateTime   @default(now()) @map("last_updated")
  
  @@unique([competitionId, userId])
  @@index([competitionId, rank])
  @@map("competition_leaderboard")
}

model CompetitionAchievement {
  id            String           @id @default(cuid())
  competitionId String           @map("competition_id")
  competition   TradingCompetition @relation(fields: [competitionId], references: [id])
  userId        String           @map("user_id")
  user          User             @relation(fields: [userId], references: [id])
  type          AchievementType
  title         String
  description   String
  icon          String?
  earnedAt      DateTime         @default(now()) @map("earned_at")
  shared        Boolean          @default(false)
  shareUrl      String?          @map("share_url")
  
  @@map("competition_achievements")
}

model AntiCheatFlag {
  id             String         @id @default(cuid())
  competitionId  String         @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id])
  type           FlagType
  severity       FlagSeverity
  description    String
  evidence       Json?
  status         FlagStatus     @default(PENDING)
  reviewedBy     String?        @map("reviewed_by")
  reviewedAt     DateTime?      @map("reviewed_at")
  action         String?
  createdAt      DateTime       @default(now()) @map("created_at")
  
  @@index([competitionId, userId])
  @@index([status])
  @@map("anti_cheat_flags")
}

model PrizeDistribution {
  id             String     @id @default(cuid())
  competitionId  String     @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String     @map("user_id")
  user           User       @relation(fields: [userId], references: [id])
  rank           Int
  prizeAmount    Decimal    @map("prize_amount")
  currency       String     @default("USD")
  status         PrizeStatus @default(PENDING)
  transactionHash String?   @map("transaction_hash")
  distributedAt  DateTime?  @map("distributed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  
  @@index([competitionId, userId])
  @@index([status])
  @@map("prize_distributions")
}

// Enums for Trading Competition

enum CompetitionType {
  HIGHEST_RETURN
  MOST_VOLUME
  BEST_SHARPE
  HIGHEST_WINS
  LOWEST_DRAWDOWN
}

enum DurationType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum CompetitionStatus {
  UPCOMING
  ACTIVE
  FINISHED
  CANCELLED
  SUSPENDED
}

enum ParticipantStatus {
  REGISTERED
  ACTIVE
  FINISHED
  DISQUALIFIED
  WITHDRAWN
}

enum TradeSide {
  BUY
  SELL
}

enum AchievementType {
  FIRST_PLACE
  TOP_THREE
  TOP_TEN
  HIGHEST_RETURN
  MOST_VOLUME
  BEST_RISK_ADJUSTED
  WIN_STREAK
  CONSISTENT_PERFORMANCE
}

enum FlagType {
  WASH_TRADING
  SELF_DEALING
  MANIPULATION
  BOTS
  MULTIPLE_ACCOUNTS
  UNUSUAL_PATTERN
}

enum FlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FlagStatus {
  PENDING
  REVIEWING
  CONFIRMED
  DISMISSED
  ACTION_TAKEN
}

enum PrizeStatus {
  PENDING
  APPROVED
  PAID
  FAILED
  CANCELLED
}
